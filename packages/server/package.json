{
  "name": "@spool-ai/server",
  "version": "0.3.0",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@hono/node-server": "^1.13.0",
    "@spool-ai/collector": "^0.3.0",
    "@spool-ai/shared": "^0.3.0",
    "@spool-ai/spec": "^0.3.0",
    "hono": "^4.6.0",
    "shiki": "^1.29.2",
    "@spool-ai/claude-code-adapter": "^0.3.0",
    "@spool-ai/codex-cli-adapter": "^0.3.0",
    "@spool-ai/cursor-adapter": "^0.3.0",
    "@spool-ai/store-postgres": "^0.3.0"
  },
  "description": "Spool web inspector: Hono server, fork/replay engine, live fleet view",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HoneycombHairDevelopers/Spool.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/HoneycombHairDevelopers/Spool#readme",
  "bugs": {
    "url": "https://github.com/HoneycombHairDevelopers/Spool/issues"
  },
  "engines": {
    "node": ">=20.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true
  },
  "scripts": {
    "build": "tsup"
  }
}
