{
  "name": "@meterbility/cli",
  "version": "0.3.1",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "meter": "dist/index.js"
  },
  "dependencies": {
    "@meterbility/shared": "^0.3.0",
    "@meterbility/spec": "^0.3.0",
    "@meterbility/collector": "^0.3.0",
    "@meterbility/server": "^0.3.0",
    "@meterbility/claude-code-adapter": "^0.3.0",
    "@meterbility/codex-cli-adapter": "^0.3.0",
    "@meterbility/cursor-adapter": "^0.3.0",
    "@meterbility/agent": "^0.3.0",
    "@meterbility/proxy": "^0.3.0",
    "@meterbility/store-postgres": "^0.3.0",
    "commander": "^12.1.0",
    "picocolors": "^1.0.0",
    "@anthropic-ai/sdk": "^0.30.0"
  },
  "description": "Meterbility: the debugger for AI agents — capture, inspect, fork, replay, live-probe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HoneycombHairDevelopers/Meterbility.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/HoneycombHairDevelopers/Meterbility#readme",
