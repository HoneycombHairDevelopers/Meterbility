    "@spool-ai/collector": "^0.3.0",
    "@spool-ai/server": "^0.3.0",
    "@spool-ai/claude-code-adapter": "^0.3.0",
    "@spool-ai/codex-cli-adapter": "^0.3.0",
    "@spool-ai/cursor-adapter": "^0.3.0",
    "@spool-ai/agent": "^0.3.0",
    "@spool-ai/proxy": "^0.3.0",
    "@spool-ai/store-postgres": "^0.3.0",
    "commander": "^12.1.0",
    "picocolors": "^1.0.0",
    "@anthropic-ai/sdk": "^0.30.0"
  },
  "description": "Spool: the debugger for AI agents — capture, inspect, fork, replay, live-probe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HoneycombHairDevelopers/Spool.git",
    "directory": "packages/cli"
  },
