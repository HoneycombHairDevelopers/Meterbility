{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "isolatedModules": true,
    "lib": [
      "ES2023",
      "DOM"
    ],
    "baseUrl": ".",
    "paths": {
      "@meterbility/shared": [
        "packages/shared/src/index.ts"
      ],
      "@meterbility/spec": [
        "packages/spec/src/index.ts"
      ],
      "@meterbility/agent": [
        "packages/agent/src/index.ts"
      ],
      "@meterbility/collector": [
        "packages/collector/src/index.ts"
      ],
      "@meterbility/store-postgres": [
        "packages/store-postgres/src/index.ts"
      ],
      "@meterbility/proxy": [
        "packages/proxy/src/index.ts"
      ],
      "@meterbility/server": [
        "packages/server/src/index.ts"
      ],
      "@meterbility/claude-code-adapter": [
        "adapters/claude-code/src/index.ts"
      ],
      "@meterbility/codex-cli-adapter": [
        "adapters/codex-cli/src/index.ts"
      ],
      "@meterbility/cursor-adapter": [
        "adapters/cursor/src/index.ts"
      ]
    }
  }
}
